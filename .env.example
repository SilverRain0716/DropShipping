# .env.example
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CJ Dropshipping 크롤러 환경 변수 템플릿
# 복사: cp .env.example .env 후 실제 값 입력
# ⚠️ .env 파일은 절대 Git에 커밋하지 말 것 (.gitignore에 추가 필수)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── CJ Dropshipping API
# 발급 위치: https://developers.cjdropshipping.com → My Account → API
CJ_EMAIL=your_cj_email@example.com
CJ_API_KEY=your_cj_api_key_here

# ── Google Sheets
# Sheets URL에서 /d/ 뒤 문자열 복사
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# ── GCP 서비스 계정 JSON 경로 (로컬 실행 시)
GCP_CREDENTIALS_JSON=gcp_credentials.json

# ── Discord 웹훅
# Discord 채널 설정 → 연동 → 웹훅 → URL 복사
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── Webshare Rotating Proxy
# ⚠️ 판매 계정(Etsy/스마트스토어/쿠팡)과 절대 동일 프록시 사용 금지
# 발급: https://proxy.webshare.io
PROXY_USER=your_proxy_username
PROXY_PASS=your_proxy_password
PROXY_HOST=p.webshare.io
PROXY_PORT=80
